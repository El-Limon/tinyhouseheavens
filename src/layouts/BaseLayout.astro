---
import type { Locale } from '../i18n/utils';
import { t, getAlternateLocales, getLocalizedPathForLocale } from '../i18n/utils';
import '../styles/global.css';
import StructuredData from '../components/StructuredData.astro';
import CookieConsent from '../components/CookieConsent.astro';

interface Props {
  locale: Locale;
  title: string;
  description: string;
  image?: string;
  noIndex?: boolean;
}

const { locale, title, description, image, noIndex = false } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const alternateLocales = getAlternateLocales(locale);
const ogImage = image || '/images/brand/og-default.webp';

const ogLocaleMap: Record<Locale, string> = { nl: 'nl_BE', fr: 'fr_BE', en: 'en_GB' };
---

<!doctype html>
<html lang={locale} class="scroll-smooth" data-locale={locale}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="alternate" hreflang={locale} href={canonicalURL} />
  {alternateLocales.map(alt => {
    const altPath = getLocalizedPathForLocale(locale, alt, Astro.url.pathname);
    return <link rel="alternate" hreflang={alt} href={new URL(altPath, Astro.site)} />;
  })}
  <link rel="alternate" hreflang="x-default" href={new URL(getLocalizedPathForLocale(locale, 'nl', Astro.url.pathname), Astro.site)} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(ogImage, Astro.site)} />
  <meta property="og:locale" content={ogLocaleMap[locale]} />
  {alternateLocales.map(alt => (
    <meta property="og:locale:alternate" content={ogLocaleMap[alt]} />
  ))}
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content="Tiny House Heavens" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />
  <!-- Google Search Console verification — replace YOUR_VERIFICATION_CODE with actual code -->
  <meta name="google-site-verification" content="rX-L_Maqj5wRIcJQBThxZ6mhKoA5kZd0CdmYEpg3Tec" />
  {noIndex && <meta name="robots" content="noindex, nofollow" />}
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <!-- GA4 — loaded dynamically by CookieConsent when user accepts -->
  <script is:inline>
    window.GA_MEASUREMENT_ID = 'G-97VPC8S4KD';
    window.loadGA4 = function() {
      if (document.getElementById('ga4-script')) return;
      var s = document.createElement('script');
      s.id = 'ga4-script';
      s.async = true;
      s.src = 'https://www.googletagmanager.com/gtag/js?id=' + window.GA_MEASUREMENT_ID;
      document.head.appendChild(s);
      window.dataLayer = window.dataLayer || [];
      function gtag(){window.dataLayer.push(arguments);}
      window.gtag = gtag;
      gtag('js', new Date());
      gtag('config', window.GA_MEASUREMENT_ID);
    };
    if (localStorage.getItem('cookie-consent') === 'accepted') {
      window.loadGA4();
    }
  </script>
</head>
<body class="bg-thh-cream text-thh-charcoal antialiased">
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-thh-green-500 focus:text-white focus:px-4 focus:py-2 focus:rounded-md focus:font-medium focus:shadow-lg">
    {t(locale, 'common.skip_to_content')}
  </a>
  <StructuredData type="organization" locale={locale} />
  <slot />
  <CookieConsent locale={locale} />
</body>
</html>

<style is:global>
  h1, h2, h3 {
    font-family: 'Playfair Display', serif;
  }
  body {
    font-family: 'DM Sans', sans-serif;
  }
</style>
