---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/Hero.astro';
import ModelCard from '../../components/ModelCard.astro';
import BrandPillars from '../../components/BrandPillars.astro';
import FinishingLevels from '../../components/FinishingLevels.astro';
import Testimonials from '../../components/Testimonials.astro';
import StructuredData from '../../components/StructuredData.astro';
import { getCollection } from 'astro:content';
import { t, getPagePath } from '../../i18n/utils';

const locale = 'en';
const models = await getCollection('models');
const featuredModels = models.filter(m => m.data.featured).sort((a, b) => a.data.sortOrder - b.data.sortOrder);
---

<PageLayout locale={locale} title={t(locale, 'seo.home_title')} description={t(locale, 'seo.home_desc')}>

  <StructuredData type="localBusiness" locale={locale} />
  <StructuredData type="webSite" locale={locale} />

  <!-- Hero -->
  <Hero
    locale={locale}
    title="Simple living, great thinking"
    subtitle={t(locale, 'hero.subtitle')}
    ctaText={t(locale, 'hero.cta')}
    ctaLink={getPagePath(locale, 'models')}
    secondaryCta={t(locale, 'hero.quote_cta')}
    secondaryCtaLink={getPagePath(locale, 'contact')}
  />

  <!-- Brand Pillars -->
  <BrandPillars locale={locale} />

  <!-- Featured Models -->
  <section class="py-20 bg-thh-cream">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-bold mb-4 text-thh-charcoal">{t(locale, 'popular.title')}</h2>
        <p class="text-lg text-thh-charcoal/70 max-w-2xl mx-auto">
          {t(locale, 'popular.subtitle')}
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {featuredModels.map((model) => (
          <ModelCard locale={locale} model={model.data} />
        ))}
      </div>
      <div class="text-center mt-10">
        <a href={getPagePath(locale, 'models')} class="inline-flex items-center gap-2 px-6 py-3 border-2 border-thh-green-600 text-thh-green-600 font-semibold rounded-lg hover:bg-thh-green-600 hover:text-white transition-colors">
          {t(locale, 'models.all_models')}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-bold mb-4 text-thh-charcoal">{t(locale, 'how_it_works.title')}</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        {[1, 2, 3].map((step) => (
          <div class="text-center relative">
            <div class="text-6xl font-bold text-thh-green-100 mb-4">{`0${step}`}</div>
            <h3 class="text-xl font-bold mb-3 text-thh-charcoal">{t(locale, `how_it_works.step${step}.title`)}</h3>
            <p class="text-thh-charcoal/70 leading-relaxed">{t(locale, `how_it_works.step${step}.desc`)}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Finishing Levels -->
  <FinishingLevels locale={locale} />

  <!-- Visits by appointment -->
  <section class="py-16 bg-thh-green-50/50">
    <div class="max-w-3xl mx-auto px-6">
      <div class="bg-white rounded-2xl shadow-sm border border-thh-green-100 p-10 text-center">
        <div class="w-14 h-14 mx-auto mb-5 rounded-full bg-thh-green-50 flex items-center justify-center">
          <svg class="w-7 h-7 text-thh-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
          </svg>
        </div>
        <h3 class="text-xl md:text-2xl font-bold text-thh-charcoal mb-3">{t(locale, 'contact.by_appointment_title')}</h3>
        <p class="text-base md:text-lg text-thh-charcoal/70 max-w-xl mx-auto">{t(locale, 'contact.by_appointment_home')}</p>
        <div class="mt-6 flex flex-wrap gap-4 justify-center text-sm">
          <a href="tel:+32465600263" class="inline-flex items-center gap-2 text-thh-green-600 font-medium hover:text-thh-green-700 transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
            +32 465 600 263
          </a>
          <a href="mailto:info@tinyhouseheavens.com" class="inline-flex items-center gap-2 text-thh-green-600 font-medium hover:text-thh-green-700 transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
            info@tinyhouseheavens.com
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <Testimonials locale={locale} />

  <!-- SEO Content Section -->
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-3xl md:text-4xl font-bold mb-8 text-thh-charcoal text-center">{t(locale, 'home_content.section_title')}</h2>
      <div class="prose prose-lg max-w-none text-thh-charcoal/80 leading-relaxed space-y-6">
        <p>{t(locale, 'home_content.paragraph_1')}</p>
        <p>{t(locale, 'home_content.paragraph_2')}</p>
        <p>{t(locale, 'home_content.paragraph_3')}</p>
      </div>
      <div class="text-center mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a href={getPagePath(locale, 'models')} class="inline-flex items-center gap-2 px-6 py-3 bg-thh-green-600 text-white font-semibold rounded-lg hover:bg-thh-green-700 transition-colors">
          {t(locale, 'cta.view_models')}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
        <a href={getPagePath(locale, 'contact')} class="inline-flex items-center gap-2 px-6 py-3 border-2 border-thh-green-600 text-thh-green-600 font-semibold rounded-lg hover:bg-thh-green-600 hover:text-white transition-colors">
          {t(locale, 'cta.request_quote')}
        </a>
      </div>
    </div>
  </section>

</PageLayout>
