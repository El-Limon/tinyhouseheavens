---
import PageLayout from '../../layouts/PageLayout.astro';
import StructuredData from '../../components/StructuredData.astro';
import FinishingLevels from '../../components/FinishingLevels.astro';
import { t, getPagePath } from '../../i18n/utils';

const locale = 'en';

const services = [1, 2, 3].map((n) => ({
  name: t(locale, `how_it_works.step${n}.title`),
  description: t(locale, `how_it_works.step${n}.desc`),
}));

const procesSteps = [1, 2, 3, 4, 5, 6].map((n) => t(locale, `services.proces.step${n}`));
---

<PageLayout locale={locale} title={t(locale, 'seo.services_title')} description={t(locale, 'seo.services_desc')}>

  <StructuredData type="service" locale={locale} services={services} />
  <StructuredData type="breadcrumb" locale={locale} breadcrumbs={[
    { name: 'Home', url: `/${locale}/` },
    { name: t(locale, 'services.title'), url: getPagePath(locale, 'services') },
  ]} />

  <!-- Hero -->
  <section class="pt-32 pb-16 bg-gradient-to-b from-thh-green-50/50 to-thh-cream">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4 text-thh-charcoal">{t(locale, 'services.title')}</h1>
      <p class="text-lg text-thh-charcoal/70 max-w-2xl mx-auto">
        {t(locale, 'services.hero_subtitle')}
      </p>
    </div>
  </section>

  <!-- 3-step workflow -->
  <section class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-bold mb-4 text-thh-charcoal">{t(locale, 'how_it_works.title')}</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        {[1, 2, 3].map((step) => (
          <div class="text-center relative">
            <div class="text-6xl font-bold text-thh-green-100 mb-4">{`0${step}`}</div>
            <h3 class="text-xl font-bold mb-3 text-thh-charcoal">{t(locale, `how_it_works.step${step}.title`)}</h3>
            <p class="text-thh-charcoal/70 leading-relaxed">{t(locale, `how_it_works.step${step}.desc`)}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Finishing Levels / Packages -->
  <FinishingLevels locale={locale} />

  <!-- 6-step Proces Timeline -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold mb-3 text-thh-charcoal">{t(locale, 'services.proces_title')}</h2>
        <p class="text-thh-charcoal/70">{t(locale, 'services.proces_subtitle')}</p>
      </div>
      <div class="space-y-8">
        {procesSteps.map((step, i) => (
          <div class="flex items-start gap-6">
            <div class="w-12 h-12 shrink-0 bg-thh-green-600 text-white rounded-full flex items-center justify-center font-bold text-lg">
              {i + 1}
            </div>
            <div class="pt-2.5">
              <p class="text-lg font-medium text-thh-charcoal">{step}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-20 bg-thh-green-50/50">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4 text-thh-charcoal">{t(locale, 'services.final_cta_title')}</h2>
      <p class="text-lg text-thh-charcoal/70 mb-8">{t(locale, 'services.final_cta_desc')}</p>
      <a href={getPagePath(locale, 'contact')} class="inline-flex items-center gap-2 px-8 py-4 bg-thh-green-600 text-white font-semibold rounded-lg hover:bg-thh-green-700 transition-colors">
        {t(locale, 'services.final_cta_button')}
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </a>
    </div>
  </section>

</PageLayout>
