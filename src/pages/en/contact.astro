---
import PageLayout from '../../layouts/PageLayout.astro';
import QuoteRequestForm from '../../components/QuoteRequestForm.astro';
import { t, getPagePath } from '../../i18n/utils';

const locale = 'en';
const success = Astro.url.searchParams.get('success') === 'true';
---

<PageLayout locale={locale} title={t(locale, 'seo.contact_title')} description={t(locale, 'seo.contact_desc')}>

  <!-- Hero -->
  <section class="pt-32 pb-12 bg-gradient-to-b from-thh-green-50/50 to-thh-cream">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4 text-thh-charcoal">{t(locale, 'contact.title')}</h1>
      <p class="text-lg text-thh-charcoal/70 max-w-2xl mx-auto">
        Have questions or want to request a quote? We are happy to help.
      </p>
    </div>
  </section>

  <!-- Success Message -->
  {success && (
    <section class="pb-4 bg-thh-cream">
      <div class="max-w-3xl mx-auto px-6">
        <div class="bg-thh-green-50 border border-thh-green-200 rounded-2xl p-6 text-center">
          <svg class="w-12 h-12 mx-auto mb-3 text-thh-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <p class="text-lg font-semibold text-thh-green-700">{t(locale, 'contact.success')}</p>
        </div>
      </div>
    </section>
  )}

  <!-- Contact Content -->
  <section class="py-12 bg-thh-cream">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-10">

        <!-- Form (3 cols) -->
        <div class="lg:col-span-3">
          <QuoteRequestForm locale={locale} />
        </div>

        <!-- Contact Info (2 cols) -->
        <div class="lg:col-span-2 space-y-8">

          <!-- Address -->
          <div class="bg-white rounded-2xl p-8 shadow-sm">
            <h3 class="text-lg font-bold mb-4 text-thh-charcoal">{t(locale, 'contact.address_label')}</h3>
            <div class="flex items-start gap-3 mb-4">
              <svg class="w-5 h-5 text-thh-green-500 mt-1 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0115 0z" />
              </svg>
              <div class="text-thh-charcoal/70">
                <p class="font-medium text-thh-charcoal">Tiny House Heavens</p>
                <p>Fort 15</p>
                <p>2860 Sint-Katelijne-Waver</p>
                <p>Belgium</p>
              </div>
            </div>
          </div>

          <!-- Phone & Email -->
          <div class="bg-white rounded-2xl p-8 shadow-sm">
            <h3 class="text-lg font-bold mb-4 text-thh-charcoal">{t(locale, 'contact.details')}</h3>
            <div class="space-y-4">
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-thh-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                </svg>
                <a href="tel:+32465600263" class="text-thh-charcoal/70 hover:text-thh-green-600 transition-colors">+32 465 600 263</a>
              </div>
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-thh-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                </svg>
                <a href="mailto:info@tinyhouseheavens.com" class="text-thh-charcoal/70 hover:text-thh-green-600 transition-colors">info@tinyhouseheavens.com</a>
              </div>
            </div>
          </div>

          <!-- Social -->
          <div class="bg-white rounded-2xl p-8 shadow-sm">
            <h3 class="text-lg font-bold mb-4 text-thh-charcoal">{t(locale, 'contact.follow')}</h3>
            <div class="flex gap-3">
              <a href="https://www.facebook.com/tinyhouseheavens" target="_blank" rel="noopener noreferrer" class="w-12 h-12 bg-thh-green-50 text-thh-green-600 rounded-xl flex items-center justify-center hover:bg-thh-green-500 hover:text-white transition-colors" aria-label="Facebook">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" /></svg>
              </a>
              <a href="https://www.instagram.com/tinyhouseheavens" target="_blank" rel="noopener noreferrer" class="w-12 h-12 bg-thh-green-50 text-thh-green-600 rounded-xl flex items-center justify-center hover:bg-thh-green-500 hover:text-white transition-colors" aria-label="Instagram">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" /></svg>
              </a>
            </div>
          </div>

          <!-- BTW -->
          <div class="text-sm text-thh-charcoal/40">
            <p>VAT: BE0403.670.250</p>
          </div>

        </div>
      </div>
    </div>
  </section>

</PageLayout>
