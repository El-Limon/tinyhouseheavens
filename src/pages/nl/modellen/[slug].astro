---
import PageLayout from '../../../layouts/PageLayout.astro';
import ModelCard from '../../../components/ModelCard.astro';
import QuoteRequestForm from '../../../components/QuoteRequestForm.astro';
import FinishingLevels from '../../../components/FinishingLevels.astro';
import CTASection from '../../../components/CTASection.astro';
import ImageLightbox from '../../../components/ImageLightbox.astro';
import StructuredData from '../../../components/StructuredData.astro';
import { getCollection } from 'astro:content';
import { t, getModelPath, getPagePath } from '../../../i18n/utils';

export async function getStaticPaths() {
  const models = await getCollection('models');
  return models.map(model => ({
    params: { slug: model.data.slug },
    props: { model: model.data },
  }));
}

const locale = 'nl';
const { model } = Astro.props;
const allModels = await getCollection('models');
const relatedModels = allModels
  .filter(m => m.data.category === model.category && m.data.slug !== model.slug)
  .slice(0, 3);

const dimensionsFormatted = `${(model.dimensions.length / 1000).toFixed(1)} x ${(model.dimensions.width / 1000).toFixed(1)} m`;
---

<PageLayout locale={locale} title={`${model.name} Tiny House | ${model.buildingArea}m² ${t(locale, `categories.${model.category}`)} | Tiny House Heavens`} description={`${model.name} tiny house: ${model.buildingArea}m² modulaire woning. ${model.tagline.nl} Bekijk specificaties en vraag een offerte aan.`}>

  <StructuredData type="product" locale={locale} product={{
    name: model.name,
    slug: model.slug,
    description: model.description.nl,
    image: model.heroImage,
    images: model.galleryImages,
    category: t(locale, `categories.${model.category}`),
    buildingArea: model.buildingArea,
    livingArea: model.livingArea,
    dimensions: model.dimensions,
  }} />
  <StructuredData type="breadcrumb" locale={locale} breadcrumbs={[
    { name: 'Home', url: `/${locale}/` },
    { name: t(locale, 'nav.models'), url: getPagePath(locale, 'models') },
    { name: model.name, url: getModelPath(locale, model.slug) },
  ]} />

  <!-- Breadcrumb -->
  <section class="pt-28 pb-4 bg-thh-cream">
    <div class="max-w-7xl mx-auto px-6">
      <nav class="flex items-center gap-2 text-sm text-thh-charcoal/50" aria-label="Breadcrumb">
        <a href={`/${locale}/`} class="hover:text-thh-green-600 transition-colors">Home</a>
        <span>/</span>
        <a href={getPagePath(locale, 'models')} class="hover:text-thh-green-600 transition-colors">Modellen</a>
        <span>/</span>
        <span class="text-thh-charcoal font-medium">{model.name}</span>
      </nav>
    </div>
  </section>

  <!-- Hero Section -->
  <section class="pb-12 bg-thh-cream">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">

        <!-- Hero Image -->
        <div class="aspect-[4/3] rounded-2xl overflow-hidden shadow-sm bg-thh-green-50 cursor-pointer group relative" data-lightbox-trigger="0">
          <img
            src={model.heroImage}
            alt={`${model.name} modulaire tiny house ${model.buildingArea}m² buitenaanzicht`}
            class="w-full h-full object-cover"
            loading="eager"
            fetchpriority="high"
            width="800"
            height="600"
          />
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-colors duration-300 flex items-center justify-center">
            <svg class="w-10 h-10 text-white opacity-0 group-hover:opacity-100 transition-opacity duration-300 drop-shadow-lg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" />
            </svg>
          </div>
        </div>

        <!-- Info -->
        <div class="py-4">
          <span class="inline-block text-xs font-semibold text-thh-green-600 bg-thh-green-50 px-3 py-1.5 rounded-full uppercase tracking-wider mb-4">
            {t(locale, `categories.${model.category}`)}
          </span>
          <h1 class="text-4xl md:text-5xl font-bold text-thh-charcoal mb-3">{model.name}</h1>
          <p class="text-xl text-thh-charcoal/70 mb-8 italic" style="font-family: 'Playfair Display', serif;">{model.tagline.nl}</p>

          <!-- Key Stats -->
          <div class="grid grid-cols-2 gap-4 mb-8">
            <div class="bg-white rounded-xl p-5 shadow-sm">
              <div class="text-sm text-thh-charcoal/50 mb-1">{t(locale, 'models.building_area')}</div>
              <div class="text-2xl font-bold text-thh-charcoal">{model.buildingArea} <span class="text-base font-normal">m²</span></div>
            </div>
            <div class="bg-white rounded-xl p-5 shadow-sm">
              <div class="text-sm text-thh-charcoal/50 mb-1">{t(locale, 'models.living_area')}</div>
              <div class="text-2xl font-bold text-thh-charcoal">{model.livingArea} <span class="text-base font-normal">m²</span></div>
            </div>
            <div class="bg-white rounded-xl p-5 shadow-sm">
              <div class="text-sm text-thh-charcoal/50 mb-1">{t(locale, 'models.dimensions')}</div>
              <div class="text-2xl font-bold text-thh-charcoal">{dimensionsFormatted}</div>
            </div>
            {model.terrace && (
              <div class="bg-white rounded-xl p-5 shadow-sm">
                <div class="text-sm text-thh-charcoal/50 mb-1">{t(locale, 'models.rooms.terrace')}</div>
                <div class="text-2xl font-bold text-thh-charcoal">{model.terrace} <span class="text-base font-normal">m²</span></div>
              </div>
            )}
          </div>

          <!-- Quick CTA -->
          <a href="#offerte" class="inline-flex items-center gap-2 px-8 py-4 bg-thh-green-600 text-white font-semibold rounded-lg hover:bg-thh-green-700 transition-colors shadow-md">
            {t(locale, 'common.request_quote')}
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Gallery with Lightbox -->
  <ImageLightbox
    modelName={model.name}
    heroImage={model.heroImage}
    galleryImages={model.galleryImages}
    floorplanImage={model.floorplanImage}
    galleryTitle={t(locale, 'common.gallery')}
  />

  <!-- Description -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-6">
      <p class="text-lg text-thh-charcoal/80 leading-relaxed">{model.description.nl}</p>
    </div>
  </section>

  <!-- Specifications -->
  <section class="py-16 bg-thh-cream">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-3xl font-bold mb-8 text-thh-charcoal">{t(locale, 'common.specifications')}</h2>

      <!-- Rooms -->
      <div class="bg-white rounded-2xl overflow-hidden shadow-sm mb-8">
        <table class="w-full">
          <thead>
            <tr class="bg-thh-green-50">
              <th class="text-left px-6 py-4 text-sm font-semibold text-thh-charcoal/70 uppercase tracking-wider">Ruimte</th>
              <th class="text-right px-6 py-4 text-sm font-semibold text-thh-charcoal/70 uppercase tracking-wider">Oppervlakte</th>
            </tr>
          </thead>
          <tbody>
            {model.rooms.map((room: { key: string; area: number }, i: number) => (
              room.area === 0 ? (
                <tr class="bg-thh-green-50/40">
                  <td colspan="2" class="px-6 py-3 text-center text-sm font-semibold text-thh-charcoal/70 tracking-wider">{t(locale, `models.rooms.${room.key}`)}</td>
                </tr>
              ) : (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-thh-green-50/20'}>
                  <td class="px-6 py-4 text-thh-charcoal">{t(locale, `models.rooms.${room.key}`)}</td>
                  <td class="px-6 py-4 text-right text-thh-charcoal font-medium">{room.area} m²</td>
                </tr>
              )
            ))}
          </tbody>
        </table>
      </div>

      <!-- Floor Plan -->
      <div class="mb-8">
        <h3 class="text-xl font-bold mb-4 text-thh-charcoal">{t(locale, 'common.floor_plan')}</h3>
        <div class="rounded-2xl overflow-hidden bg-white shadow-sm p-4 cursor-pointer group relative" data-lightbox-trigger={model.galleryImages.length + 1}>
          <img
            src={model.floorplanImage}
            alt={`${t(locale, 'common.floor_plan')} - ${model.name}`}
            class="w-full h-auto"
            decoding="async"
            width="1200"
            height="800"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/5 transition-colors duration-300 flex items-center justify-center">
            <svg class="w-10 h-10 text-thh-charcoal opacity-0 group-hover:opacity-60 transition-opacity duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" />
            </svg>
          </div>
        </div>
      </div>

      <!-- Features -->
      {model.features.length > 0 && (
        <div class="mb-8">
          <h3 class="text-xl font-bold mb-4 text-thh-charcoal">Kenmerken</h3>
          <div class="flex flex-wrap gap-2">
            {model.features.map((feature: string) => (
              <span class="inline-flex items-center gap-1.5 px-4 py-2 bg-thh-green-50 text-thh-green-700 rounded-full text-sm font-medium">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                {feature.replace(/_/g, ' ')}
              </span>
            ))}
          </div>
        </div>
      )}

      <!-- Variants -->
      {model.variants && model.variants.length > 0 && (
        <div class="mb-8">
          <h3 class="text-xl font-bold mb-4 text-thh-charcoal">{t(locale, 'common.variants')}</h3>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
            {model.variants.map((variant: any) => typeof variant === 'string' ? (
              <div class="bg-white rounded-xl p-5 shadow-sm border border-thh-green-100">
                <span class="text-thh-charcoal font-medium">{variant}</span>
              </div>
            ) : (
              <div class="bg-white rounded-2xl overflow-hidden shadow-sm border border-thh-green-100">
                {variant.image && (
                  <div class="aspect-[4/3] overflow-hidden">
                    <img src={variant.image} alt={variant.name} class="w-full h-full object-cover" loading="lazy" decoding="async" width="600" height="450" />
                  </div>
                )}
                <div class="p-5">
                  <h4 class="text-lg font-bold text-thh-charcoal mb-2">{variant.name}</h4>
                  {variant.description && (
                    <p class="text-sm text-thh-charcoal/70 leading-relaxed">{variant.description[locale] || variant.description.nl}</p>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- Finishing Levels -->
  <FinishingLevels locale={locale} />

  <!-- Construction Details -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-3xl font-bold mb-8 text-thh-charcoal">{t(locale, 'common.construction')}</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-thh-cream rounded-2xl p-6">
          <h3 class="text-lg font-bold mb-2 text-thh-charcoal">Wanden</h3>
          <p class="text-sm text-thh-charcoal/70 leading-relaxed">150mm isolatie, OSB beplating, winddicht membraan, geventileerde gevel</p>
        </div>
        <div class="bg-thh-cream rounded-2xl p-6">
          <h3 class="text-lg font-bold mb-2 text-thh-charcoal">Vloer</h3>
          <p class="text-sm text-thh-charcoal/70 leading-relaxed">200mm isolatie, OSB ondervloer, stalen frame onderstel</p>
        </div>
        <div class="bg-thh-cream rounded-2xl p-6">
          <h3 class="text-lg font-bold mb-2 text-thh-charcoal">Plafond</h3>
          <p class="text-sm text-thh-charcoal/70 leading-relaxed">200mm isolatie, dampscherm, afwerking naar keuze</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Quote Form -->
  <section id="offerte" class="py-16 bg-thh-green-50/30">
    <div class="max-w-3xl mx-auto px-6">
      <QuoteRequestForm locale={locale} preselectedModel={model.name} />
    </div>
  </section>

  <!-- Related Models -->
  {relatedModels.length > 0 && (
    <section class="py-16 bg-thh-cream">
      <div class="max-w-7xl mx-auto px-6">
        <h2 class="text-3xl font-bold mb-8 text-thh-charcoal">{t(locale, 'common.related_models')}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {relatedModels.map((m) => (
            <ModelCard locale={locale} model={m.data} />
          ))}
        </div>
      </div>
    </section>
  )}

</PageLayout>
