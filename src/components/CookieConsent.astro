---
import type { Locale } from '../i18n/utils';
import { t, getPagePath } from '../i18n/utils';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const privacyPath = getPagePath(locale, 'privacy');
---

<div
  id="cookie-consent"
  class="fixed bottom-0 left-0 right-0 z-50 transform translate-y-full transition-transform duration-500"
  role="dialog"
  aria-label={t(locale, 'common.cookie_notice')}
>
  <div class="bg-thh-charcoal text-white p-4 md:p-6 shadow-2xl">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center gap-4">
      <p class="text-sm md:text-base flex-1">
        {t(locale, 'cookie.message')}
        <a href={privacyPath} class="underline hover:text-thh-green-400 ml-1">{t(locale, 'common.cookie_link')}</a>
      </p>
      <div class="flex gap-3 shrink-0">
        <button
          id="cookie-decline"
          class="px-4 py-2 text-sm border border-white/30 rounded-lg hover:bg-white/10 transition-colors"
        >
          {t(locale, 'cookie.decline')}
        </button>
        <button
          id="cookie-accept"
          class="px-4 py-2 text-sm bg-thh-green-500 text-white rounded-lg hover:bg-thh-green-600 transition-colors"
        >
          {t(locale, 'cookie.accept')}
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  const banner = document.getElementById('cookie-consent');
  const acceptBtn = document.getElementById('cookie-accept');
  const declineBtn = document.getElementById('cookie-decline');

  if (!localStorage.getItem('cookie-consent')) {
    setTimeout(() => {
      banner?.classList.remove('translate-y-full');
    }, 1000);
  }

  function closeBanner(value: string) {
    localStorage.setItem('cookie-consent', value);
    banner?.classList.add('translate-y-full');
    if (value === 'accepted' && typeof (window as any).loadGA4 === 'function') {
      (window as any).loadGA4();
    }
  }

  acceptBtn?.addEventListener('click', () => closeBanner('accepted'));
  declineBtn?.addEventListener('click', () => closeBanner('declined'));
</script>
