---
import type { Locale } from '../i18n/utils';
import { t } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

// TODO: Replace with real customer testimonials
const testimonials = [
  {
    quote: {
      nl: 'De kwaliteit van onze Evoke heeft onze verwachtingen overtroffen. Van het eerste adviesgesprek tot de oplevering was alles perfect geregeld.',
      fr: 'La qualite de notre Evoke a depasse nos attentes. Du premier conseil a la livraison, tout etait parfaitement organise.',
      en: 'The quality of our Evoke exceeded our expectations. From the first consultation to delivery, everything was perfectly arranged.',
    },
    name: 'Jan D.',
    location: { nl: 'Antwerpen', fr: 'Anvers', en: 'Antwerp' },
    model: 'Evoke',
  },
  {
    quote: {
      nl: 'Wij zochten een duurzame en betaalbare woning. Met de Optima afwerking hebben we een prachtige sleutel-op-de-deur tiny house gekregen.',
      fr: 'Nous cherchions un logement durable et abordable. Avec la finition Optima, nous avons obtenu une magnifique tiny house cle en main.',
      en: 'We were looking for a sustainable and affordable home. With the Optima finish, we got a beautiful turnkey tiny house.',
    },
    name: 'Sophie V.',
    location: { nl: 'Gent', fr: 'Gand', en: 'Ghent' },
    model: 'Liora',
  },
  {
    quote: {
      nl: 'Het team van Tiny House Heavens begeleidde ons bij elke stap. De modulaire aanpak maakte het hele proces snel en transparant.',
      fr: "L'equipe de Tiny House Heavens nous a accompagne a chaque etape. L'approche modulaire a rendu tout le processus rapide et transparent.",
      en: 'The Tiny House Heavens team guided us every step of the way. The modular approach made the entire process fast and transparent.',
    },
    name: 'Marc L.',
    location: { nl: 'Brussel', fr: 'Bruxelles', en: 'Brussels' },
    model: 'Ophir',
  },
];
---

<section class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-14">
      <h2 class="text-3xl md:text-4xl font-bold mb-4 text-thh-charcoal">{t(locale, 'testimonials.title')}</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {testimonials.map((testimonial) => (
        <div class="bg-thh-green-50/30 rounded-2xl p-8 flex flex-col">
          <svg class="w-8 h-8 text-thh-green-300 mb-4 shrink-0" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
          </svg>
          <p class="text-thh-charcoal/80 leading-relaxed mb-6 flex-1">{testimonial.quote[locale]}</p>
          <div class="border-t border-thh-green-100 pt-4">
            <p class="font-bold text-thh-charcoal">{testimonial.name}</p>
            <p class="text-sm text-thh-charcoal/50">{testimonial.location[locale]} &middot; {testimonial.model}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
