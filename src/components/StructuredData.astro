---
interface BreadcrumbItem {
  name: string;
  url: string;
}

interface Props {
  type: 'organization' | 'product' | 'breadcrumb';
  locale: 'nl' | 'fr';
  breadcrumbs?: BreadcrumbItem[];
  product?: {
    name: string;
    description: string;
    image: string;
    category: string;
    buildingArea: number;
  };
}

const { type, locale, breadcrumbs, product } = Astro.props;
const siteUrl = 'https://tinyhouseheavens.com';

function getOrganizationSchema() {
  return {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'Tiny House Heavens',
    url: siteUrl,
    logo: `${siteUrl}/images/brand/logo.svg`,
    description: locale === 'nl'
      ? 'Modulaire tiny houses ontworpen voor duurzaam en betaalbaar wonen in de Benelux'
      : 'Tiny houses modulaires conçues pour un habitat durable et abordable au Benelux',
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Fort 15',
      addressLocality: 'St-Katelijne-Waver',
      postalCode: '2860',
      addressCountry: 'BE',
    },
    contactPoint: {
      '@type': 'ContactPoint',
      telephone: '+32465600263',
      email: 'info@tinyhouseheavens.com',
      contactType: 'sales',
      availableLanguage: ['Dutch', 'French'],
    },
    sameAs: [
      'https://facebook.com/profile.php?id=61573215795089',
      'https://instagram.com/tinyhouseheavens',
    ],
  };
}

function getProductSchema() {
  if (!product) return null;
  return {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: `Tiny House ${product.name}`,
    description: product.description,
    image: product.image.startsWith('http') ? product.image : `${siteUrl}${product.image}`,
    brand: { '@type': 'Brand', name: 'Tiny House Heavens' },
    category: 'Modular Homes',
    additionalProperty: {
      '@type': 'PropertyValue',
      name: locale === 'nl' ? 'Bouwoppervlakte' : 'Surface de construction',
      value: `${product.buildingArea} m²`,
    },
    offers: {
      '@type': 'Offer',
      availability: 'https://schema.org/InStock',
      priceCurrency: 'EUR',
      seller: { '@type': 'Organization', name: 'Tiny House Heavens' },
    },
  };
}

function getBreadcrumbSchema() {
  if (!breadcrumbs) return null;
  return {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumbs.map((item, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: item.name,
      item: item.url.startsWith('http') ? item.url : `${siteUrl}${item.url}`,
    })),
  };
}

const schemas: Record<string, () => any> = {
  organization: getOrganizationSchema,
  product: getProductSchema,
  breadcrumb: getBreadcrumbSchema,
};

const schema = schemas[type]?.();
---

{schema && (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
)}
