---
import type { Locale } from '../i18n/utils';
import { t } from '../i18n/utils';

interface BreadcrumbItem {
  name: string;
  url: string;
}

interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  type: 'organization' | 'product' | 'breadcrumb' | 'faqPage' | 'localBusiness' | 'webSite' | 'service' | 'person';
  locale: Locale;
  breadcrumbs?: BreadcrumbItem[];
  faqs?: FaqItem[];
  product?: {
    name: string;
    slug: string;
    description: string;
    image: string;
    images?: string[];
    category: string;
    buildingArea: number;
    livingArea?: number;
    dimensions?: { length: number; width: number };
  };
  services?: { name: string; description: string }[];
}

const { type, locale, breadcrumbs, product, faqs, services } = Astro.props;
const siteUrl = 'https://tinyhouseheavens.com';

function getOrganizationSchema() {
  return {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    '@id': `${siteUrl}/#organization`,
    name: 'Tiny House Heavens',
    url: siteUrl,
    logo: `${siteUrl}/images/brand/logo.svg`,
    description: t(locale, 'common.structured_data_desc'),
    founder: {
      '@type': 'Person',
      '@id': `${siteUrl}/#founder`,
    },
    knowsAbout: [
      'Modular tiny house construction',
      'Timber frame and steel undercarriage building',
      'Sustainable and energy-efficient housing',
      'Belgian building permits and regulations',
      'Turnkey tiny house delivery',
    ],
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Fort 15',
      addressLocality: 'Sint-Katelijne-Waver',
      postalCode: '2860',
      addressCountry: 'BE',
    },
    contactPoint: {
      '@type': 'ContactPoint',
      telephone: '+32465600263',
      email: 'info@tinyhouseheavens.com',
      contactType: 'sales',
      availableLanguage: ['Dutch', 'French', 'English'],
    },
    sameAs: [
      'https://www.facebook.com/tinyhouseheavens',
      'https://www.instagram.com/tinyhouseheavens',
      // TODO: Add LinkedIn, YouTube, Google Business Profile URLs when created
    ],
  };
}

function getProductSchema() {
  if (!product) return null;
  const imageUrl = (src: string) => src.startsWith('http') ? src : `${siteUrl}${src}`;
  const allImages = product.images
    ? [imageUrl(product.image), ...product.images.map(imageUrl)]
    : [imageUrl(product.image)];

  const schema: Record<string, any> = {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: `Tiny House ${product.name}`,
    description: product.description,
    image: allImages,
    sku: product.slug,
    brand: { '@type': 'Brand', name: 'Tiny House Heavens' },
    manufacturer: {
      '@type': 'Organization',
      name: 'Tiny House Heavens',
      url: siteUrl,
    },
    category: 'Modular Tiny Houses',
    material: 'Timber frame, steel undercarriage, OSB panels, 150-200mm insulation',
    countryOfOrigin: { '@type': 'Country', name: 'Belgium' },
    additionalProperty: [
      {
        '@type': 'PropertyValue',
        name: t(locale, 'models.building_area'),
        value: `${product.buildingArea} m²`,
      },
    ],
    offers: {
      '@type': 'Offer',
      availability: 'https://schema.org/InStock',
      priceCurrency: 'EUR',
      seller: { '@type': 'Organization', name: 'Tiny House Heavens' },
    },
  };

  if (product.livingArea) {
    schema.additionalProperty.push({
      '@type': 'PropertyValue',
      name: t(locale, 'models.living_area'),
      value: `${product.livingArea} m²`,
    });
  }

  if (product.dimensions) {
    schema.width = { '@type': 'QuantitativeValue', value: product.dimensions.width, unitCode: 'MMT' };
    schema.depth = { '@type': 'QuantitativeValue', value: product.dimensions.length, unitCode: 'MMT' };
  }

  return schema;
}

function getBreadcrumbSchema() {
  if (!breadcrumbs) return null;
  return {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumbs.map((item, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: item.name,
      item: item.url.startsWith('http') ? item.url : `${siteUrl}${item.url}`,
    })),
  };
}

function getFaqPageSchema() {
  if (!faqs || faqs.length === 0) return null;
  return {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map(faq => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: faq.answer,
      },
    })),
  };
}

function getLocalBusinessSchema() {
  return {
    '@context': 'https://schema.org',
    '@type': 'LocalBusiness',
    '@id': `${siteUrl}/#localbusiness`,
    name: 'Tiny House Heavens',
    image: `${siteUrl}/images/brand/og-default.webp`,
    url: siteUrl,
    telephone: '+32465600263',
    email: 'info@tinyhouseheavens.com',
    description: t(locale, 'common.structured_data_desc'),
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Fort 15',
      addressLocality: 'Sint-Katelijne-Waver',
      postalCode: '2860',
      addressRegion: 'Antwerpen',
      addressCountry: 'BE',
    },
    geo: {
      '@type': 'GeoCoordinates',
      latitude: 51.0717,
      longitude: 4.5283,
    },
    areaServed: {
      '@type': 'Place',
      name: 'Europe',
    },
    priceRange: '€€€',
    sameAs: [
      'https://www.facebook.com/tinyhouseheavens',
      'https://www.instagram.com/tinyhouseheavens',
    ],
  };
}

function getWebSiteSchema() {
  return {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Tiny House Heavens',
    url: siteUrl,
    inLanguage: ['nl', 'fr', 'en'],
    publisher: {
      '@type': 'Organization',
      name: 'Tiny House Heavens',
      url: siteUrl,
    },
  };
}

function getServiceSchema() {
  if (!services || services.length === 0) return null;
  return services.map(service => ({
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: service.name,
    description: service.description,
    provider: {
      '@type': 'LocalBusiness',
      name: 'Tiny House Heavens',
      url: siteUrl,
    },
    areaServed: { '@type': 'Country', name: 'Belgium' },
  }));
}

function getPersonSchema() {
  return {
    '@context': 'https://schema.org',
    '@type': 'Person',
    '@id': `${siteUrl}/#founder`,
    name: 'Thomas Jennes',
    jobTitle: 'Founder',
    image: `${siteUrl}/images/team/thomas-jennes.webp`,
    url: `${siteUrl}/en/about-us/`,
    worksFor: {
      '@type': 'Organization',
      '@id': `${siteUrl}/#organization`,
    },
    knowsAbout: [
      'Modular tiny house construction',
      'Timber frame building',
      'Sustainable housing in Belgium',
      'Belgian building permits',
    ],
  };
}

const schemas: Record<string, () => any> = {
  organization: getOrganizationSchema,
  product: getProductSchema,
  breadcrumb: getBreadcrumbSchema,
  faqPage: getFaqPageSchema,
  localBusiness: getLocalBusinessSchema,
  webSite: getWebSiteSchema,
  service: getServiceSchema,
  person: getPersonSchema,
};

const schema = schemas[type]?.();
---

{schema && Array.isArray(schema) && schema[0]?.['@type'] === 'Service' ? (
  schema.map((s: any) => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))
) : schema ? (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
) : null}
