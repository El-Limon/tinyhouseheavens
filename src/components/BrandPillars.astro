---
import type { Locale } from '../i18n/utils';
import { t } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const pillars = [
  {
    key: 'innovative',
    icon: `<svg viewBox="0 0 48 48" fill="none" class="w-full h-full">
      <circle cx="24" cy="24" r="20" stroke="currentColor" stroke-width="1.5" opacity="0.2"/>
      <path d="M24 10v4M24 34v4M10 24h4M34 24h4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      <path d="M17 17l2.5 2.5M28.5 28.5L31 31M31 17l-2.5 2.5M17 31l2.5-2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.6"/>
      <circle cx="24" cy="24" r="6" stroke="currentColor" stroke-width="2"/>
      <circle cx="24" cy="24" r="2" fill="currentColor"/>
    </svg>`,
  },
  {
    key: 'scalable',
    icon: `<svg viewBox="0 0 48 48" fill="none" class="w-full h-full">
      <rect x="6" y="26" width="10" height="16" rx="2" stroke="currentColor" stroke-width="2"/>
      <rect x="19" y="18" width="10" height="24" rx="2" stroke="currentColor" stroke-width="2"/>
      <rect x="32" y="8" width="10" height="34" rx="2" stroke="currentColor" stroke-width="2"/>
      <path d="M11 22v-4h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.5"/>
      <path d="M24 14v-4h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.5"/>
    </svg>`,
  },
  {
    key: 'affordable',
    icon: `<svg viewBox="0 0 48 48" fill="none" class="w-full h-full">
      <circle cx="24" cy="24" r="18" stroke="currentColor" stroke-width="2"/>
      <path d="M24 12v24" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.3"/>
      <path d="M18 20c0-2.2 2.7-4 6-4s6 1.8 6 4-2.7 4-6 4-6 1.8-6 4 2.7 4 6 4 6-1.8 6-4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    </svg>`,
  },
  {
    key: 'eco',
    icon: `<svg viewBox="0 0 48 48" fill="none" class="w-full h-full">
      <path d="M14 38c0-12 6-22 20-24-2 12-8 20-20 24z" stroke="currentColor" stroke-width="2" fill="currentColor" fill-opacity="0.1"/>
      <path d="M14 38c4-6 10-12 20-14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
      <path d="M20 32c2-4 6-8 12-10" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.3"/>
      <circle cx="14" cy="38" r="2" fill="currentColor" opacity="0.4"/>
    </svg>`,
  },
];

const sectionTitle = locale === 'nl' ? 'Waarom Tiny House Heavens?' : 'Pourquoi Tiny House Heavens?';
---

<section class="py-24 lg:py-32 bg-gradient-to-b from-thh-green-50/40 to-thh-cream relative overflow-hidden">
  <!-- Decorative background shapes -->
  <div class="absolute top-0 right-0 w-96 h-96 bg-thh-green-200/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3"></div>
  <div class="absolute bottom-0 left-0 w-72 h-72 bg-thh-wood/5 rounded-full blur-3xl translate-y-1/2 -translate-x-1/3"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-16 lg:mb-20">
      <div class="flex items-center justify-center gap-3 mb-4">
        <span class="block w-8 h-[1px] bg-thh-green-500/40"></span>
        <span class="text-xs font-bold uppercase tracking-[0.3em] text-thh-green-600">
          {locale === 'nl' ? 'Onze waarden' : 'Nos valeurs'}
        </span>
        <span class="block w-8 h-[1px] bg-thh-green-500/40"></span>
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-thh-charcoal" style="font-family: 'Playfair Display', serif;">
        {sectionTitle}
      </h2>
    </div>

    <!-- Pillars grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-6">
      {pillars.map((pillar, index) => (
        <div
          class="pillar-card group relative bg-white/60 backdrop-blur-sm rounded-2xl p-8 border border-thh-charcoal/5 hover:border-thh-green-200 hover:bg-white hover:shadow-lg hover:shadow-thh-green-500/5 transition-all duration-500"
          style={`--delay: ${index * 120}ms;`}
        >
          <!-- Icon -->
          <div class="w-14 h-14 text-thh-green-500 mb-6 group-hover:text-thh-green-600 transition-colors duration-300 group-hover:scale-110 transform origin-center">
            <Fragment set:html={pillar.icon} />
          </div>

          <!-- Title -->
          <h3 class="text-lg font-bold text-thh-charcoal mb-3 group-hover:text-thh-green-700 transition-colors duration-300" style="font-family: 'Playfair Display', serif;">
            {t(locale, `pillars.${pillar.key}.title`)}
          </h3>

          <!-- Description -->
          <p class="text-sm text-thh-charcoal/60 leading-relaxed">
            {t(locale, `pillars.${pillar.key}.desc`)}
          </p>

          <!-- Decorative corner -->
          <div class="absolute top-4 right-4 w-2 h-2 rounded-full bg-thh-green-300/0 group-hover:bg-thh-green-300 transition-all duration-500"></div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .pillar-card {
    opacity: 0;
    transform: translateY(32px);
  }
  .pillar-card.is-visible {
    animation: pillarFadeIn 0.6s ease-out forwards;
    animation-delay: var(--delay);
  }

  @keyframes pillarFadeIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  function initPillarObserver() {
    const cards = document.querySelectorAll('.pillar-card');
    if (!cards.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15, rootMargin: '0px 0px -60px 0px' }
    );

    cards.forEach((card) => observer.observe(card));
  }

  initPillarObserver();
  document.addEventListener('astro:after-swap', initPillarObserver);
</script>
