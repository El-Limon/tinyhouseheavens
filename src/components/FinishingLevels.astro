---
import type { Locale } from '../i18n/utils';
import { t, tArray } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const levels = [
  {
    key: 'house_kit',
    features: tArray(locale, 'finishing.house_kit_features'),
    highlighted: false,
    badge: null as string | null,
    icon: `<svg viewBox="0 0 40 40" fill="none" class="w-full h-full">
      <path d="M20 4L4 16h4v16h24V16h4L20 4z" stroke="currentColor" stroke-width="2" fill="none"/>
      <path d="M14 32V22h12v10" stroke="currentColor" stroke-width="1.5" stroke-dasharray="3 2"/>
    </svg>`,
  },
  {
    key: 'basic',
    features: tArray(locale, 'finishing.basic_features'),
    highlighted: false,
    badge: null as string | null,
    icon: `<svg viewBox="0 0 40 40" fill="none" class="w-full h-full">
      <path d="M20 4L4 16h4v16h24V16h4L20 4z" stroke="currentColor" stroke-width="2" fill="currentColor" fill-opacity="0.1"/>
      <path d="M14 32V22h12v10" stroke="currentColor" stroke-width="1.5"/>
      <path d="M16 26h8" stroke="currentColor" stroke-width="1" opacity="0.5"/>
    </svg>`,
  },
  {
    key: 'optima',
    features: tArray(locale, 'finishing.optima_features'),
    highlighted: true,
    badge: t(locale, 'finishing.recommended'),
    icon: `<svg viewBox="0 0 40 40" fill="none" class="w-full h-full">
      <path d="M20 4L4 16h4v16h24V16h4L20 4z" stroke="currentColor" stroke-width="2" fill="currentColor" fill-opacity="0.15"/>
      <path d="M14 32V22h12v10" stroke="currentColor" stroke-width="1.5" fill="currentColor" fill-opacity="0.08"/>
      <path d="M16 26h8M16 29h8" stroke="currentColor" stroke-width="1" opacity="0.5"/>
      <circle cx="32" cy="8" r="5" fill="currentColor" opacity="0.3"/>
      <path d="M30 8l1.5 1.5L34 6.5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>`,
  },
];
---

<section class="py-24 lg:py-32 bg-thh-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-16">
      <div class="flex items-center justify-center gap-3 mb-4">
        <span class="block w-8 h-[1px] bg-thh-green-500/40"></span>
        <span class="text-xs font-bold uppercase tracking-[0.3em] text-thh-green-600">
          {t(locale, 'finishing.section_label')}
        </span>
        <span class="block w-8 h-[1px] bg-thh-green-500/40"></span>
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-thh-charcoal mb-4" style="font-family: 'Playfair Display', serif;">
        {t(locale, 'finishing.section_title')}
      </h2>
      <p class="text-lg text-thh-charcoal/60 max-w-2xl mx-auto">
        {t(locale, 'finishing.section_subtitle')}
      </p>
    </div>

    <!-- Levels grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 items-start">
      {levels.map((level) => (
        <div
          class:list={[
            'relative rounded-2xl p-8 transition-all duration-300 hover:shadow-lg',
            level.highlighted
              ? 'bg-white border-2 border-thh-green-500 shadow-md shadow-thh-green-500/10'
              : 'bg-white border border-thh-charcoal/8 hover:border-thh-charcoal/15',
          ]}
        >
          {/* Recommended badge */}
          {level.badge && (
            <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
              <span class="inline-flex items-center gap-1.5 px-4 py-1.5 bg-thh-green-500 text-white text-xs font-bold uppercase tracking-wider rounded-full shadow-sm">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
                </svg>
                {level.badge}
              </span>
            </div>
          )}

          {/* Icon */}
          <div class:list={[
            'w-12 h-12 mb-5',
            level.highlighted ? 'text-thh-green-500' : 'text-thh-charcoal/40',
          ]}>
            <Fragment set:html={level.icon} />
          </div>

          {/* Title */}
          <h3 class="text-xl font-bold text-thh-charcoal mb-2" style="font-family: 'Playfair Display', serif;">
            {t(locale, `finishing.${level.key}`)}
          </h3>

          {/* Description */}
          <p class="text-sm text-thh-charcoal/60 mb-6 leading-relaxed">
            {t(locale, `finishing.${level.key}_desc`)}
          </p>

          {/* Divider */}
          <div class:list={[
            'h-px mb-6',
            level.highlighted
              ? 'bg-gradient-to-r from-thh-green-300 via-thh-green-200 to-transparent'
              : 'bg-thh-charcoal/10',
          ]}></div>

          {/* Features list */}
          <ul class="space-y-3">
            {level.features.map((feature) => (
              <li class="flex items-start gap-2.5 text-sm text-thh-charcoal/70">
                <svg
                  class:list={[
                    'w-4 h-4 mt-0.5 shrink-0',
                    level.highlighted ? 'text-thh-green-500' : 'text-thh-green-400/60',
                  ]}
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2.5"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                <span>{feature}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Extra costs note -->
    <div class="mt-10 text-center">
      <p class="inline-flex items-center gap-2 text-sm text-thh-charcoal/50 italic">
        <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z" />
        </svg>
        {t(locale, 'finishing.extra_costs_note')}
      </p>
    </div>
  </div>
</section>
