---
import type { Locale } from '../i18n/utils';
import { t, getPagePath, getAlternateLocales, getLocalizedPathForLocale } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const allLocales: Locale[] = ['nl', 'fr', 'en'];

const navItems = [
  { key: 'home', page: '', path: `/${locale}` },
  { key: 'models', page: 'models', path: getPagePath(locale, 'models') },
  { key: 'about', page: 'about', path: getPagePath(locale, 'about') },
  { key: 'services', page: 'services', path: getPagePath(locale, 'services') },
  { key: 'contact', page: 'contact', path: getPagePath(locale, 'contact') },
  { key: 'faq', page: 'faq', path: getPagePath(locale, 'faq') },
  { key: 'blog', page: 'blog', path: getPagePath(locale, 'blog') },
];

const ctaText = t(locale, 'hero.quote_cta');
const contactPath = getPagePath(locale, 'contact');

const currentPath = Astro.url.pathname;
const localePaths: Record<string, string> = {};
for (const l of allLocales) {
  localePaths[l] = l === locale ? currentPath : getLocalizedPathForLocale(locale, l, currentPath);
}
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-40 transition-all duration-500 ease-out"
  data-scrolled="false"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20 lg:h-24">

      <!-- Logo -->
      <a href={`/${locale}`} class="flex items-center gap-2.5 group" aria-label="Tiny House Heavens Home">
        <div class="w-9 h-9 flex items-center justify-center">
          <svg viewBox="0 0 36 36" fill="none" class="w-full h-full" aria-hidden="true">
            <path d="M18 3L3 16h4v14h22V16h4L18 3z" fill="currentColor" class="text-thh-green-500 group-hover:text-thh-green-600 transition-colors" />
            <path d="M14 30V21h8v9" stroke="white" stroke-width="1.5" fill="none" />
            <path d="M26 10c2-1 4 0 5 2s0 4-2 4c-1 0-2-1-2-1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" class="text-thh-green-400" fill="none" />
            <path d="M28.5 8c1-2 3-2 4-1s1 3-1 4" stroke="currentColor" stroke-width="1" stroke-linecap="round" class="text-thh-green-300" fill="none" />
          </svg>
        </div>
        <div class="flex flex-col leading-none">
          <span class="text-sm sm:text-base font-semibold tracking-[0.2em] uppercase" style="font-family: 'Playfair Display', serif;">
            Tiny House
          </span>
          <span class="text-[10px] sm:text-xs tracking-[0.35em] uppercase text-thh-green-600 font-medium">
            Heavens
          </span>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
        {navItems.map(item => (
          <a
            href={item.path}
            class:list={[
              'relative px-3 py-2 text-sm font-medium transition-colors duration-300 hover:text-thh-green-600',
              'after:absolute after:bottom-0 after:left-3 after:right-3 after:h-[1.5px] after:bg-thh-green-500',
              'after:origin-left after:scale-x-0 hover:after:scale-x-100 after:transition-transform after:duration-300',
              currentPath === item.path || (item.key !== 'home' && currentPath.startsWith(item.path))
                ? 'text-thh-green-600 after:scale-x-100'
                : 'text-thh-charcoal/80',
            ]}
          >
            {t(locale, `nav.${item.key}`)}
          </a>
        ))}
      </nav>

      <!-- Right side: lang switcher + CTA + hamburger -->
      <div class="flex items-center gap-3 sm:gap-4">

        <!-- Language Switcher -->
        <div class="hidden sm:flex items-center bg-thh-charcoal/5 rounded-full p-0.5 text-xs font-semibold">
          {allLocales.map(l => (
            <a
              href={localePaths[l]}
              class:list={[
                'px-3 py-1.5 rounded-full transition-all duration-300',
                locale === l
                  ? 'bg-thh-green-500 text-white shadow-sm'
                  : 'text-thh-charcoal/60 hover:text-thh-charcoal',
              ]}
            >
              {l.toUpperCase()}
            </a>
          ))}
        </div>

        <!-- CTA Button -->
        <a
          href={contactPath}
          class="hidden md:inline-flex items-center gap-2 px-5 py-2.5 bg-thh-green-500 text-white text-sm font-semibold rounded-full hover:bg-thh-green-600 transition-all duration-300 hover:shadow-lg hover:shadow-thh-green-500/25 active:scale-[0.98]"
        >
          {ctaText}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>

        <!-- Mobile Hamburger -->
        <button
          id="mobile-menu-btn"
          class="lg:hidden flex flex-col items-center justify-center w-10 h-10 gap-1.5"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <span class="hamburger-line w-6 h-[2px] bg-thh-charcoal rounded-full transition-all duration-300 origin-center"></span>
          <span class="hamburger-line w-6 h-[2px] bg-thh-charcoal rounded-full transition-all duration-300 origin-center"></span>
          <span class="hamburger-line w-4 h-[2px] bg-thh-charcoal rounded-full transition-all duration-300 origin-center ml-auto"></span>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Drawer -->
  <div
    id="mobile-menu"
    class="fixed inset-0 z-50 pointer-events-none lg:hidden"
    aria-hidden="true"
  >
    <!-- Backdrop -->
    <div class="mobile-backdrop absolute inset-0 bg-thh-charcoal/40 opacity-0 transition-opacity duration-300"></div>

    <!-- Drawer Panel -->
    <div class="mobile-drawer absolute top-0 right-0 w-full max-w-sm h-full bg-thh-cream shadow-2xl translate-x-full transition-transform duration-500 ease-out">
      <div class="flex flex-col h-full">

        <!-- Drawer header -->
        <div class="flex items-center justify-between px-6 h-20 border-b border-thh-charcoal/10">
          <span class="text-sm font-semibold tracking-[0.2em] uppercase" style="font-family: 'Playfair Display', serif;">
            Menu
          </span>
          <button id="mobile-menu-close" class="w-10 h-10 flex items-center justify-center" aria-label="Close menu">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <!-- Drawer nav -->
        <nav class="flex-1 overflow-y-auto px-6 py-8" aria-label="Mobile navigation">
          <ul class="space-y-1">
            {navItems.map((item, i) => (
              <li>
                <a
                  href={item.path}
                  class:list={[
                    'flex items-center gap-3 px-4 py-3.5 rounded-xl text-base font-medium transition-all duration-200',
                    currentPath === item.path || (item.key !== 'home' && currentPath.startsWith(item.path))
                      ? 'bg-thh-green-50 text-thh-green-700'
                      : 'text-thh-charcoal/80 hover:bg-thh-green-50/50 hover:text-thh-charcoal',
                  ]}
                  style={`animation-delay: ${i * 50}ms`}
                >
                  {t(locale, `nav.${item.key}`)}
                </a>
              </li>
            ))}
          </ul>
        </nav>

        <!-- Drawer footer -->
        <div class="px-6 py-6 border-t border-thh-charcoal/10 space-y-4">
          <!-- Mobile lang switcher -->
          <div class="flex items-center gap-2">
            <span class="text-xs text-thh-charcoal/50 uppercase tracking-wider font-medium">
              {t(locale, 'common.language')}
            </span>
            <div class="flex items-center bg-thh-charcoal/5 rounded-full p-0.5 text-sm font-semibold">
              {allLocales.map(l => (
                <a
                  href={localePaths[l]}
                  class:list={[
                    'px-4 py-1.5 rounded-full transition-all duration-300',
                    locale === l ? 'bg-thh-green-500 text-white' : 'text-thh-charcoal/60',
                  ]}
                >{l.toUpperCase()}</a>
              ))}
            </div>
          </div>

          <a
            href={contactPath}
            class="flex items-center justify-center gap-2 w-full px-6 py-3.5 bg-thh-green-500 text-white font-semibold rounded-full hover:bg-thh-green-600 transition-colors"
          >
            {ctaText}
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</header>

<style>
  @reference "tailwindcss";
  @reference "../styles/global.css";
  /* Scrolled state */
  #site-header[data-scrolled="true"] {
    @apply bg-thh-cream/90 backdrop-blur-xl shadow-sm;
  }
  #site-header[data-scrolled="true"] > div > .flex {
    @apply h-16 lg:h-18;
  }

  /* Mobile menu open state */
  #mobile-menu.is-open {
    @apply pointer-events-auto;
  }
  #mobile-menu.is-open .mobile-backdrop {
    @apply opacity-100;
  }
  #mobile-menu.is-open .mobile-drawer {
    @apply translate-x-0;
  }

  /* Hamburger animation */
  #mobile-menu-btn.is-open .hamburger-line:nth-child(1) {
    transform: translateY(5px) rotate(45deg);
  }
  #mobile-menu-btn.is-open .hamburger-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  #mobile-menu-btn.is-open .hamburger-line:nth-child(3) {
    width: 1.5rem;
    transform: translateY(-5px) rotate(-45deg);
  }
</style>

<script>
  function initHeader() {
    const header = document.getElementById('site-header');
    const menuBtn = document.getElementById('mobile-menu-btn');
    const menuClose = document.getElementById('mobile-menu-close');
    const mobileMenu = document.getElementById('mobile-menu');
    const backdrop = mobileMenu?.querySelector('.mobile-backdrop');

    // Scroll detection
    let ticking = false;
    function onScroll() {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          if (header) {
            header.dataset.scrolled = window.scrollY > 40 ? 'true' : 'false';
          }
          ticking = false;
        });
        ticking = true;
      }
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // Mobile menu toggle
    function openMenu() {
      mobileMenu?.classList.add('is-open');
      menuBtn?.classList.add('is-open');
      menuBtn?.setAttribute('aria-expanded', 'true');
      mobileMenu?.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }
    function closeMenu() {
      mobileMenu?.classList.remove('is-open');
      menuBtn?.classList.remove('is-open');
      menuBtn?.setAttribute('aria-expanded', 'false');
      mobileMenu?.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    menuBtn?.addEventListener('click', () => {
      const isOpen = mobileMenu?.classList.contains('is-open');
      isOpen ? closeMenu() : openMenu();
    });
    menuClose?.addEventListener('click', closeMenu);
    backdrop?.addEventListener('click', closeMenu);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && mobileMenu?.classList.contains('is-open')) {
        closeMenu();
      }
    });
  }

  // Run on initial load and on Astro view transitions
  initHeader();
  document.addEventListener('astro:after-swap', initHeader);
</script>
