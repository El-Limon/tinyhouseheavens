---
import type { Locale } from '../i18n/utils';
import { t, getModelPath } from '../i18n/utils';

interface Props {
  locale: Locale;
  model: {
    name: string;
    slug: string;
    category: string;
    buildingArea: number;
    livingArea: number;
    heroImage: string;
  };
}

const { locale, model } = Astro.props;
const modelPath = getModelPath(locale, model.slug);
const viewText = t(locale, 'models.view_model');
const categoryText = t(locale, `categories.${model.category}`);
const buildingLabel = t(locale, 'models.building_area');
const livingLabel = t(locale, 'models.living_area');

const categoryColors: Record<string, string> = {
  entry: 'bg-thh-green-100 text-thh-green-700',
  small: 'bg-sky-100 text-sky-700',
  medium: 'bg-amber-100 text-amber-700',
  large: 'bg-violet-100 text-violet-700',
  special: 'bg-rose-100 text-rose-700',
};
const badgeColor = categoryColors[model.category] ?? 'bg-thh-green-100 text-thh-green-700';
---

<article class="group relative bg-thh-cream rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-500 hover:-translate-y-1.5">

  <!-- Image container -->
  <a href={modelPath} class="block aspect-[4/3] overflow-hidden relative" tabindex="-1" aria-hidden="true">
    {model.heroImage ? (
      <img
        src={model.heroImage}
        alt={`${model.name} tiny house`}
        class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-110"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full bg-gradient-to-br from-thh-green-100 via-thh-green-50 to-thh-cream flex items-center justify-center">
        <div class="text-center">
          <svg class="w-16 h-16 mx-auto text-thh-green-300/60 mb-3" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M24 6L4 22h6v18h28V22h6L24 6z" />
            <rect x="18" y="28" width="12" height="12" rx="1" />
          </svg>
          <span class="text-2xl font-bold text-thh-green-300/50" style="font-family: 'Playfair Display', serif;">
            {model.name}
          </span>
        </div>
      </div>
    )}

    <!-- Gradient overlay on hover -->
    <div class="absolute inset-0 bg-gradient-to-t from-thh-charcoal/30 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

    <!-- Category badge -->
    <span class={`absolute top-4 left-4 text-[11px] font-bold uppercase tracking-wider px-3 py-1.5 rounded-full backdrop-blur-sm ${badgeColor}`}>
      {categoryText}
    </span>
  </a>

  <!-- Content -->
  <div class="p-5 sm:p-6">

    <!-- Model name -->
    <h3 class="text-xl font-bold text-thh-charcoal group-hover:text-thh-green-600 transition-colors duration-300 mb-4" style="font-family: 'Playfair Display', serif;">
      <a href={modelPath} class="after:absolute after:inset-0">
        {model.name}
      </a>
    </h3>

    <!-- Stats -->
    <div class="flex items-center gap-4 text-sm text-thh-charcoal/60 mb-4">
      <div class="flex items-center gap-2 flex-1 min-w-0">
        <svg class="w-4 h-4 shrink-0 text-thh-green-500/70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15" />
        </svg>
        <div class="min-w-0">
          <span class="text-thh-charcoal/40 text-xs block leading-tight truncate">{buildingLabel}</span>
          <span class="font-semibold text-thh-charcoal">{model.buildingArea} m²</span>
        </div>
      </div>
      <div class="w-px h-8 bg-thh-charcoal/10 shrink-0"></div>
      <div class="flex items-center gap-2 flex-1 min-w-0">
        <svg class="w-4 h-4 shrink-0 text-thh-wood/70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
        </svg>
        <div class="min-w-0">
          <span class="text-thh-charcoal/40 text-xs block leading-tight truncate">{livingLabel}</span>
          <span class="font-semibold text-thh-charcoal">{model.livingArea} m²</span>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="h-px bg-gradient-to-r from-thh-green-200/50 via-thh-charcoal/10 to-transparent mb-4"></div>

    <!-- View link -->
    <div class="flex items-center justify-between">
      <span class="text-sm font-semibold text-thh-green-600 group-hover:text-thh-green-700 transition-colors">
        {viewText}
      </span>
      <svg
        class="w-5 h-5 text-thh-green-500 transform translate-x-0 group-hover:translate-x-1.5 transition-transform duration-300"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </div>
  </div>
</article>
