---
import type { Locale } from '../i18n/utils';

interface Props {
  locale: Locale;
  title: string;
  subtitle: string;
  ctaText: string;
  ctaLink: string;
  secondaryCta?: string;
  secondaryCtaLink?: string;
  backgroundImage?: string;
}

const {
  locale,
  title,
  subtitle,
  ctaText,
  ctaLink,
  secondaryCta,
  secondaryCtaLink,
  backgroundImage,
} = Astro.props;

const scrollLabel = locale === 'nl' ? 'Scroll naar beneden' : 'Faites défiler';
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">

  <!-- Background -->
  {backgroundImage ? (
    <div class="absolute inset-0">
      <img
        src={backgroundImage}
        alt=""
        class="w-full h-full object-cover scale-105 hero-parallax"
        loading="eager"
      />
      <!-- Gradient overlay -->
      <div class="absolute inset-0 bg-gradient-to-b from-thh-charcoal/70 via-thh-charcoal/40 to-thh-charcoal/80"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-thh-green-900/30 to-transparent"></div>
    </div>
  ) : (
    <div class="absolute inset-0 bg-gradient-to-br from-thh-cream via-thh-green-50 to-thh-cream">
      <!-- Geometric pattern for no-image state -->
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: url(&quot;data:image/svg+xml,%3Csvg width='120' height='120' viewBox='0 0 120 120' xmlns='http://www.w3.org/2000/svg'%3E%3Crect width='120' height='120' fill='none'/%3E%3Cpolygon points='60,10 110,40 110,100 60,130 10,100 10,40' fill='none' stroke='%232D2D2D' stroke-width='0.5'/%3E%3C/svg%3E&quot;); background-size: 120px 120px;"></div>
      <!-- Decorative floating shapes -->
      <div class="absolute top-1/4 right-1/4 w-96 h-96 bg-thh-green-200/20 rounded-full blur-3xl animate-float-slow"></div>
      <div class="absolute bottom-1/3 left-1/6 w-72 h-72 bg-thh-wood/10 rounded-full blur-3xl animate-float-slow" style="animation-delay: -3s;"></div>
    </div>
  )}

  <!-- Content -->
  <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-32">
    <!-- Decorative line -->
    <div class="flex items-center justify-center gap-4 mb-8">
      <span class:list={[
        'block w-12 h-[1px]',
        backgroundImage ? 'bg-white/30' : 'bg-thh-green-500/30',
      ]}></span>
      <svg class:list={['w-5 h-5', backgroundImage ? 'text-thh-green-400' : 'text-thh-green-500']} viewBox="0 0 20 20" fill="currentColor">
        <path d="M10 2L7 8H3l5 4-2 6 4-3 4 3-2-6 5-4h-4L10 2z" />
      </svg>
      <span class:list={[
        'block w-12 h-[1px]',
        backgroundImage ? 'bg-white/30' : 'bg-thh-green-500/30',
      ]}></span>
    </div>

    <h1
      class:list={[
        'text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold leading-[1.1] tracking-tight mb-6 hero-title',
        backgroundImage ? 'text-white' : 'text-thh-charcoal',
      ]}
      style="font-family: 'Playfair Display', serif; letter-spacing: -0.02em;"
    >
      {title}
    </h1>

    <p
      class:list={[
        'text-lg sm:text-xl md:text-2xl max-w-2xl mx-auto mb-10 leading-relaxed hero-subtitle',
        backgroundImage ? 'text-white/80' : 'text-thh-charcoal/60',
      ]}
    >
      {subtitle}
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 hero-ctas">
      <!-- Primary CTA -->
      <a
        href={ctaLink}
        class="inline-flex items-center gap-2.5 px-8 py-4 bg-thh-green-500 text-white font-bold rounded-full hover:bg-thh-green-600 transition-all duration-300 hover:shadow-xl hover:shadow-thh-green-500/30 active:scale-[0.98] text-base"
      >
        {ctaText}
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>

      <!-- Secondary CTA -->
      {secondaryCta && secondaryCtaLink && (
        <a
          href={secondaryCtaLink}
          class:list={[
            'inline-flex items-center gap-2.5 px-8 py-4 font-semibold rounded-full transition-all duration-300 active:scale-[0.98] text-base border-2',
            backgroundImage
              ? 'border-white/40 text-white hover:bg-white/10 hover:border-white/60'
              : 'border-thh-charcoal/20 text-thh-charcoal hover:border-thh-green-500 hover:text-thh-green-600',
          ]}
        >
          {secondaryCta}
        </a>
      )}
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2">
    <span class:list={[
      'text-[10px] uppercase tracking-[0.3em] font-medium',
      backgroundImage ? 'text-white/40' : 'text-thh-charcoal/30',
    ]}>
      {scrollLabel}
    </span>
    <div class="scroll-indicator">
      <svg
        class:list={['w-5 h-5 animate-bounce-gentle', backgroundImage ? 'text-white/50' : 'text-thh-green-500/50']}
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7" />
      </svg>
    </div>
  </div>
</section>

<style>
  .hero-parallax {
    will-change: transform;
  }

  .hero-title {
    animation: heroFadeUp 0.8s ease-out both;
  }
  .hero-subtitle {
    animation: heroFadeUp 0.8s ease-out 0.15s both;
  }
  .hero-ctas {
    animation: heroFadeUp 0.8s ease-out 0.3s both;
  }

  @keyframes heroFadeUp {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes bounceGentle {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }
  .animate-bounce-gentle {
    animation: bounceGentle 2s ease-in-out infinite;
  }

  @keyframes floatSlow {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(20px, -20px); }
  }
  .animate-float-slow {
    animation: floatSlow 12s ease-in-out infinite;
  }
</style>

<script>
  function initHeroParallax() {
    const parallaxEl = document.querySelector('.hero-parallax');
    if (!parallaxEl) return;

    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          const scrolled = window.scrollY;
          const rate = scrolled * 0.3;
          (parallaxEl as HTMLElement).style.transform = `scale(1.05) translateY(${rate}px)`;
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  }

  initHeroParallax();
  document.addEventListener('astro:after-swap', initHeroParallax);
</script>
